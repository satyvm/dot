#!/usr/bin/env bash
set -euo pipefail

warn() { printf 'warning: %s\n' "$*" >&2; }

if command -v herdr >/dev/null 2>&1; then
  for agent in claude pi opencode; do
    if command -v "$agent" >/dev/null 2>&1; then
      if [[ "$agent" == "pi" ]]; then
        PI_CODING_AGENT_DIR="$HOME/.pi/agent" herdr integration install "$agent" || warn "Could not install Herdr integration for $agent"
      else
        herdr integration install "$agent" || warn "Could not install Herdr integration for $agent"
      fi
    fi
  done
else
  warn "Herdr is missing; agent integrations were skipped"
fi

{{- if eq .aiMode "local" }}
if ! command -v brew >/dev/null 2>&1; then
  warn "Homebrew is missing; local CLIProxyAPI service setup was skipped"
  exit 0
fi

proxy_config="$HOME/.config/cli-proxy-api/config.yaml"
brew_proxy_config="$(brew --prefix)/etc/cliproxyapi.conf"
if [[ -f "$proxy_config" ]]; then
  mkdir -p "$(dirname "$brew_proxy_config")"
  ln -sfn "$proxy_config" "$brew_proxy_config"
else
  warn "CLIProxyAPI config is missing; run chezmoi apply"
fi

if [[ -s "$HOME/.config/cli-proxy-api/client-key" ]]; then
  brew services restart cliproxyapi || warn "CLIProxyAPI did not start; retry brew services restart cliproxyapi"
else
  warn "CLIProxyAPI device keys are not initialized; run ax auth setup"
fi
{{- end }}
