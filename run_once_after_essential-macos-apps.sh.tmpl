{{- if eq .chezmoi.os "darwin" -}}
#!/bin/bash
set -euo pipefail

echo "Removing non-essential stock macOS apps..."

APPS_TO_REMOVE=(
  "GarageBand"
  "iMovie"
  "Keynote"
  "Numbers"
  "Pages"
)

for app in "${APPS_TO_REMOVE[@]}"; do
  app_path="/Applications/${app}.app"
  sys_path="/System/Applications/${app}.app"

  if [ -d "$app_path" ]; then
    echo "  🗑️  Removing $app (user)..."
    sudo rm -rf "$app_path" 2>/dev/null || true
  elif [ -d "$sys_path" ]; then
    echo "  🗑️  Removing $app (system)..."
    sudo rm -rf "$sys_path" 2>/dev/null || true
  else
    echo "  ✅ $app already removed or not found"
  fi
done

echo "macOS app cleanup complete."

echo "installing node lts using fnm"
fnm install --lts
corepack enable
corepack prepare pnpm@latest --activate

{{ end -}}
