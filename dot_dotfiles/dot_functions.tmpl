# .functions

# mcd : Makes a new dir and jumps into it.

function mcd() {
	mkdir -p "$1" && cd "$1";
}

# zipf : To create a ZIP archive of a folder

function zipf() {
	zip -r "$1".zip "$1" ;
}

# extract : extract any file with this command.

extract () {
  if [ -f $1 ] ; then
    case $1 in
      *.tar.bz2)   tar xjf $1     ;;
      *.tar.gz)    tar xzf $1     ;;
      *.bz2)       bunzip2 $1     ;;
      *.rar)       unrar e $1     ;;
      *.gz)        gunzip $1      ;;
      *.tar)       tar xf $1      ;;
      *.tbz2)      tar xjf $1     ;;
      *.tgz)       tar xzf $1     ;;
      *.zip)       unzip $1       ;;
      *.Z)         uncompress $1  ;;
      *.7z)        7z x $1        ;;
      *)     echo "'$1' cannot be extracted via extract()" ;;
       esac
   else
       echo "'$1' is not a valid file"
   fi
}

# search : interactive ripgrep → fzf → editor

function search() {
  rg --color=always --line-number --no-heading "${@}" |
    fzf --ansi --delimiter : \
        --preview 'bat --color=always --highlight-line {2} {1}' \
        --preview-window '~3:+{2}+3/2' |
    awk -F: '{print "+"$2, $1}' | xargs -r $EDITOR
}

# help : colorized --help output via bat

function help() {
  "$@" --help 2>&1 | bat --plain --language=help
}

{{- if not (and (eq .chezmoi.os "darwin") (eq .profile "dev")) }}
# Outside macOS dev, keep native commands as direct pass-throughs. The ax
# platform and its generated profiles are intentionally not deployed there.
function claude() {
  command claude "$@"
}

function pi() {
  command pi "$@"
}

function opencode() {
  command opencode "$@"
}

function crush() {
  command crush "$@"
}
{{- end }}

# charm : compatibility name for Crush
function charm() {
  crush "$@"
}
