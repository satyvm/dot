# ── zsh-autosuggestions ──────────────────────────────────────────────
ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE='fg=248'
{{- if eq .chezmoi.os "darwin" }}
if [[ -f /opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh ]]; then
  source /opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh
fi
{{- else }}
for _zas in \
  /home/linuxbrew/.linuxbrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh \
  /usr/share/zsh-autosuggestions/zsh-autosuggestions.zsh; do
  if [[ -f "$_zas" ]]; then source "$_zas"; break; fi
done
unset _zas
{{- end }}

# ── zsh-history-substring-search ────────────────────────────────────
HISTORY_SUBSTRING_SEARCH_HIGHLIGHT_FOUND=''
HISTORY_SUBSTRING_SEARCH_HIGHLIGHT_NOT_FOUND=''
{{- if eq .chezmoi.os "darwin" }}
if [[ -f /opt/homebrew/share/zsh-history-substring-search/zsh-history-substring-search.zsh ]]; then
  source /opt/homebrew/share/zsh-history-substring-search/zsh-history-substring-search.zsh
fi
{{- else }}
for _zhss in \
  /home/linuxbrew/.linuxbrew/share/zsh-history-substring-search/zsh-history-substring-search.zsh \
  /usr/share/zsh-history-substring-search/zsh-history-substring-search.zsh; do
  if [[ -f "$_zhss" ]]; then source "$_zhss"; break; fi
done
unset _zhss
{{- end }}
bindkey '^[[A' history-substring-search-up
bindkey '^[[B' history-substring-search-down

# ── fnm (Node version manager) ──────────────────────────────────────
if command -v fnm &> /dev/null; then
  eval "$(fnm env --use-on-cd)"
fi

# ── Mise (global tool manager) ──────────────────────────────────────
if command -v mise &> /dev/null; then
  eval "$(mise activate zsh)"
fi

# ── Zoxide (smart cd) ───────────────────────────────────────────────
if command -v zoxide &> /dev/null; then
  eval "$(zoxide init zsh)"
fi

# ── fzf (deferred for faster shell startup) ─────────────────────────
if command -v fzf &> /dev/null; then
  function _fzf_defer() {
    eval "$(fzf --zsh)"
    add-zsh-hook -d precmd _fzf_defer
  }
  autoload -Uz add-zsh-hook
  add-zsh-hook precmd _fzf_defer
fi

# ── thefuck ─────────────────────────────────────────────────────────
if command -v thefuck &> /dev/null; then
  eval "$(thefuck --alias)"
  eval "$(thefuck --alias fk)"
fi

# ── History opts ────────────────────────────────────────────────────
setopt appendhistory
setopt share_history
setopt incappendhistory
setopt hist_ignore_all_dups
setopt hist_save_no_dups
setopt hist_ignore_dups
setopt hist_find_no_dups
setopt hist_verify