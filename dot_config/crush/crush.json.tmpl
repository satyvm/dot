{
  "$schema": "https://charm.land/crush.json",
  "options": {
    "context_paths": [
      "{{ .chezmoi.homeDir }}/.config/agents/universal_context.md"
    ]
  },
  "providers": {
    "cliproxy": {
      "type": "openai-compat",
      "base_url": "{{ if eq .aiMode "remote" }}http://cliproxyapi:8317{{ else }}{{ .aiAgentPlatform.proxy.url }}{{ end }}/v1",
      "api_key": "$OPENAI_API_KEY",
      "models": [
{{- $roles := .aiAgentPlatform.roles -}}
{{- range $index, $role := list "frontier" "balanced" "fast" "light" -}}
{{- $model := index $roles $role }}
        {
          "id": "{{ $role }}",
          "name": "{{ $model.displayName }}",
          "context_window": {{ $model.contextWindow }},
          "default_max_tokens": {{ $model.maxTokens }}
        }{{ if lt $index 3 }},{{ end }}
{{- end }}
      ]
    }
  },
  "models": {
    "large": {
      "model": "{{ .aiAgentPlatform.classes.crush.large }}",
      "provider": "cliproxy",
      "max_tokens": {{ (index .aiAgentPlatform.roles .aiAgentPlatform.classes.crush.large).maxTokens }}
    },
    "small": {
      "model": "{{ .aiAgentPlatform.classes.crush.small }}",
      "provider": "cliproxy"
    }
  }
}
