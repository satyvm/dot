{
  "$schema": "https://charm.land/crush.json",
  "options": {
    "context_paths": [
      "{{ .chezmoi.homeDir }}/.config/agents/universal_context.md"
    ]
  },
  "mcp": {
{{- $environment := "mac-dev" -}}
{{- if eq .aiMode "remote" }}{{ $environment = "remote-dev" }}{{ end -}}
{{- $devRoot := index .aiTools.paths.devRoot $environment -}}
{{- $mcpServers := .aiTools.mcp.servers -}}
{{- range $index, $name := keys $mcpServers | sortAlpha }}
{{- $server := index $mcpServers $name }}
    "{{ $name }}": {
      "type": "stdio",
      "command": "{{ $server.command }}",
      "args": [{{ range $argIndex, $arg := $server.args }}{{ if $argIndex }}, {{ end }}{{ if eq $arg "$DEV_ROOT" }}{{ $devRoot | quote }}{{ else }}{{ $arg | quote }}{{ end }}{{ end }}],
      "timeout": 120,
      "disabled": false
    }{{ if lt $index (sub (len $mcpServers) 1) }},{{ end }}
{{- end }}
  },
  "lsp": {
{{- $lspServers := .aiTools.lsp.servers -}}
{{- range $index, $name := keys $lspServers | sortAlpha }}
{{- $server := index $lspServers $name }}
    "{{ $name }}": {
      "command": "{{ $server.command }}",
      "args": {{ $server.args | toJson }}
    }{{ if lt $index (sub (len $lspServers) 1) }},{{ end }}
{{- end }}
  },
  "providers": {
    "cliproxy": {
      "type": "openai-compat",
      "base_url": "{{ if eq .aiMode "remote" }}http://cliproxyapi:8317{{ else }}{{ .aiAgentPlatform.proxy.url }}{{ end }}/v1",
      "api_key": "$OPENAI_API_KEY",
      "models": [
{{- $roles := .aiAgentPlatform.roles -}}
{{- range $index, $role := list "frontier" "balanced" "fast" "light" -}}
{{- $model := index $roles $role }}
        {
          "id": "{{ $role }}",
          "name": "{{ $model.displayName }}",
          "context_window": {{ $model.contextWindow }},
          "default_max_tokens": {{ $model.maxTokens }}
        }{{ if lt $index 3 }},{{ end }}
{{- end }}
      ]
    }
  },
  "models": {
    "large": {
      "model": "{{ .aiAgentPlatform.classes.crush.large }}",
      "provider": "cliproxy",
      "max_tokens": {{ (index .aiAgentPlatform.roles .aiAgentPlatform.classes.crush.large).maxTokens }}
    },
    "small": {
      "model": "{{ .aiAgentPlatform.classes.crush.small }}",
      "provider": "cliproxy"
    }
  }
}
