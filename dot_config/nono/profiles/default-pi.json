{
  "meta": {
    "name": "default-pi",
    "version": "1.0.0",
    "description": "ax-managed Pi coding agent profile"
  },
  "extends": "default-agent",
  "filesystem": {
    "allow": [
      "$HOME/.config/pi/agent/sessions"
    ],
    "read": [
      "$HOME/.config/pi/agent"
    ],
    "allow_file": [
      "$HOME/.config/pi/agent/models-store.json"
    ],
    "deny": [
      "$HOME/.config/pi/agent/auth.json",
      "$HOME/.config/pi/agent/credentials.json"
    ]
  }
}
