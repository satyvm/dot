{
  "meta": {
    "name": "default-claude",
    "version": "1.0.0",
    "description": "ax-managed Claude Code profile"
  },
  "extends": "default-agent",
  "filesystem": {
    "allow": [
      "$HOME/.claude/backups",
      "$HOME/.claude/cache",
      "$HOME/.claude/daemon",
      "$HOME/.claude/file-history",
      "$HOME/.claude/ide",
      "$HOME/.claude/jobs",
      "$HOME/.claude/paste-cache",
      "$HOME/.claude/plans",
      "$HOME/.claude/projects",
      "$HOME/.claude/session-env",
      "$HOME/.claude/sessions",
      "$HOME/.claude/shell-snapshots",
      "$HOME/.claude/tasks",
      "$HOME/.claude/telemetry"
    ],
    "read": [
      "$HOME/.claude"
    ],
    "allow_file": [
      "$HOME/.claude.json",
      "$HOME/.claude.json.lock",
      "$HOME/.claude/.claude.json",
      "$HOME/.claude/.last-cleanup",
      "$HOME/.claude/daemon.lock",
      "$HOME/.claude/daemon.log",
      "$HOME/.claude/daemon.status.json",
      "$HOME/.claude/history.jsonl"
    ],
    "deny": [
      "$HOME/.claude/.credentials.json"
    ]
  }
}
