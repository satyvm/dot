{
  "meta": {
    "name": "default-crush",
    "version": "1.0.0",
    "description": "Default Nono profile for Crush/Charm agent extending default-claude profile"
  },
  "extends": "default-claude",
  "groups": {
    "include": [
      "user_caches_macos",
      "git_config",
      "unlink_protection"
    ]
  },
  "filesystem": {
    "allow": [
      "$HOME/.config/crush",
      "$HOME/.local/share/crush",
      "$HOME/.local/state/crush"
    ],
    "allow_file": [
      "$HOME/.config/herdr/herdr.sock"
    ],
    "read": [
      "/home",
      "$HOME/.config/agents/",
      "$HOME/.local/state/fnm_multishells/",
      "$HOME/.local/share/fnm/",
      "$HOME/.local/share/",
      "$HOME/.fnm/",
      "$HOME/.nvm/"
    ]
  },
  "workdir": {
    "access": "readwrite"
  }
}
