{
  "meta": {
    "name": "default-crush",
    "version": "1.0.0",
    "description": "ax-managed Crush profile"
  },
  "extends": "default-agent",
  "filesystem": {
    "allow": [
      "$HOME/.local/share/crush",
      "$HOME/.local/state/crush",
      "$HOME/.cache/crush"
    ],
    "read": [
      "$HOME/.config/crush"
    ],
    "deny": [
      "$HOME/.config/crush/auth.json",
      "$HOME/.local/share/crush/auth.json",
      "$HOME/.local/share/crush/hyper.json"
    ]
  }
}
