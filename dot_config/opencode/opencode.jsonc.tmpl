{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "instructions": [
    "{{ .chezmoi.homeDir }}/.config/agents/universal_context.md"
  ],
  "enabled_providers": ["cliproxy"],
  "model": "cliproxy/{{ .aiAgentPlatform.agents.opencode.defaultRole }}",
  "small_model": "cliproxy/light",
  "mcp": {
{{- $environment := "mac-dev" -}}
{{- if eq .aiMode "remote" }}{{ $environment = "remote-dev" }}{{ end -}}
{{- $devRoot := index .aiTools.paths.devRoot $environment -}}
{{- $servers := .aiTools.mcp.servers -}}
{{- range $index, $name := keys $servers | sortAlpha }}
{{- $server := index $servers $name }}
    "{{ $name }}": {
      "type": "local",
      "command": [{{ $server.command | quote }}{{ range $arg := $server.args }}, {{ if eq $arg "$DEV_ROOT" }}{{ $devRoot | quote }}{{ else }}{{ $arg | quote }}{{ end }}{{ end }}],
      "enabled": true
    }{{ if lt $index (sub (len $servers) 1) }},{{ end }}
{{- end }}
  },
  "provider": {
    "cliproxy": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "CLIProxyAPI",
      "options": {
        "baseURL": "{{ if eq .aiMode "remote" }}http://cliproxyapi:8317{{ else }}{{ .aiAgentPlatform.proxy.url }}{{ end }}/v1",
        "apiKey": "{env:OPENAI_API_KEY}",
        "timeout": 600000,
        "chunkTimeout": 60000
      },
      "models": {
{{- $roles := .aiAgentPlatform.roles -}}
{{- range $index, $role := list "frontier" "balanced" "fast" "light" }}
        "{{ $role }}": {
          "id": "{{ $role }}",
          "name": "{{ (index $roles $role).displayName }}",
          "family": "canonical",
          "limit": {
            "context": {{ (index $roles $role).contextWindow }},
            "output": {{ (index $roles $role).maxTokens }}
          },
          "modalities": {
            "input": {{ (index $roles $role).input | toJson }},
            "output": ["text"]
          },
          "reasoning": {{ (index $roles $role).reasoning }}
        }{{ if lt $index 3 }},{{ end }}
{{- end }}
      }
    }
  }
}
