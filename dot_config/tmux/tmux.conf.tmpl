# Enable RGB color and undercurl support
set -g default-terminal "tmux-256color"
set -as terminal-overrides ',*:Smulx=\E[4::%p1%dm'  # undercurl support
set -as terminal-overrides ',*:Setulc=\E[58::2::%p1%{65536}%/%d::%p1%{256}%/%{255}%&%d::%p1%{255}%&%d%;m'  # underscore colors

set -g prefix C-a
unbind C-b
bind-key C-a send-prefix

unbind %
bind | split-window -h -c "#{pane_current_path}"

unbind '"'
bind - split-window -v -c "#{pane_current_path}"

unbind r
bind r source-file ~/.config/tmux/tmux.conf

bind j resize-pane -D 5
bind k resize-pane -U 5
bind l resize-pane -R 5
bind h resize-pane -L 5

bind -r m resize-pane -Z

bind M-c attach-session -c "#{pane_current_path}"

set -g mouse on

set -g allow-passthrough on
set -s set-clipboard on

set-window-option -g mode-keys vi

bind-key -T copy-mode-vi 'v' send -X begin-selection # start selecting text with "v"
bind-key -T copy-mode-vi 'y' send -X copy-selection # copy text with "y"

unbind -T copy-mode-vi MouseDragEnd1Pane # don't exit copy mode when dragging with mouse

# remove delay for exiting insert mode with ESC in Neovim
set -sg escape-time 10

# tpm plugin
set -g @plugin 'tmux-plugins/tpm'

# list of tmux plugins
set -g @plugin 'christoomey/vim-tmux-navigator'
set -g @plugin 'tmux-plugins/tmux-resurrect' # persist tmux sessions after computer restart
set -g @plugin 'tmux-plugins/tmux-continuum' # automatically saves sessions for you every 15 minutes
set -g @resurrect-capture-pane-contents 'on'
set -g @continuum-restore 'on'

# Use transparent background for status bar
set -g status-style bg=default,fg=colour245

# Align status bar elements
set -g status-justify left
set -g status-left-length 50
set -g status-right-length 150

# Custom Pane Borders (Thin, clean, minimalist)
set -g pane-border-style "fg=#1F2335" # Dark charcoal
set -g pane-active-border-style "fg=#7AA2F7" # Subtle slate blue/cyan accent

# Left Side: Minimal session name with a clean indicator
set -g status-left "#[fg=#7AA2F7,bold]󰘓 #S #[fg=#3B4261]│ "

# Right Side: Just date and time in a very clean format
set -g status-right "#[fg=#565F89]󰃭 %b %d #[fg=#3B4261]│ #[fg=#C0CAF5,bold]󱑒 %I:%M %p "

# Window Status (Tabs)
setw -g window-status-style bg=default,fg=#565F89
setw -g window-status-format " #I:#W "

# Active window: highlighted text, bold, with a small dot
setw -g window-status-current-style bg=default,fg=#7AA2F7,bold
setw -g window-status-current-format " #[fg=#7AA2F7]●#[fg=#C0CAF5] #I:#W "

# Message / Command Bar (Sleek pop-up styling)
set -g message-style bg=#1F2335,fg=#7AA2F7,bold

# Initialize TMUX plugin manager (keep this line at the very bottom of tmux.conf)
{{- if eq .chezmoi.os "darwin" }}
{{-   if eq .chezmoi.arch "arm64" }}
run 'if [ -f /opt/homebrew/opt/tpm/share/tpm/tpm ]; then /opt/homebrew/opt/tpm/share/tpm/tpm; elif [ -f ~/.tmux/plugins/tpm/tpm ]; then ~/.tmux/plugins/tpm/tpm; fi'
{{-   else }}
run 'if [ -f /usr/local/opt/tpm/share/tpm/tpm ]; then /usr/local/opt/tpm/share/tpm/tpm; elif [ -f ~/.tmux/plugins/tpm/tpm ]; then ~/.tmux/plugins/tpm/tpm; fi'
{{-   end }}
{{- else if eq .chezmoi.os "linux" }}
run 'if [ -f /home/linuxbrew/.linuxbrew/opt/tpm/share/tpm/tpm ]; then /home/linuxbrew/.linuxbrew/opt/tpm/share/tpm/tpm; elif [ -f ~/.tmux/plugins/tpm/tpm ]; then ~/.tmux/plugins/tpm/tpm; fi'
{{- else }}
run 'if [ -f ~/.tmux/plugins/tpm/tpm ]; then ~/.tmux/plugins/tpm/tpm; fi'
{{- end }}
