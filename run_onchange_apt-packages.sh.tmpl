{{- if eq .chezmoi.os "linux" -}}
#!/bin/bash
set -eufo pipefail

sudo apt update

{{- if or (eq .profile "dev") (eq .profile "server") }}
sudo apt install -y \
  zsh \
  git \
  wget \
  python3 \
  python3-pip \
  python3-venv \
  unzip \
  ufw

if ! command -v docker &> /dev/null; then
  echo "🐳 Installing Docker..."
  curl -fsSL https://get.docker.com | sh
  sudo usermod -aG docker "${USER:-$(id -un)}"
fi

sudo apt install -y docker-compose-plugin
{{- end }}

{{- if eq .profile "server" }}
sudo apt install -y \
  fail2ban
{{- end }}

{{ end -}}
