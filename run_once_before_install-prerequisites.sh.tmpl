#!/bin/bash
set -eufo pipefail

{{- if eq .chezmoi.os "darwin" }}
if ! command -v op &> /dev/null; then
  echo "🔐 Installing 1Password CLI..."
  brew install 1password-cli
fi
{{- end }}

{{- if eq .chezmoi.os "linux" }}
if ! command -v op &> /dev/null; then
  echo "🔐 1Password CLI not found. Please install it before continuing."
  echo "   See: https://developer.1password.com/docs/cli/get-started/#install"
  exit 1
fi
{{- end }}

if ! op account list &> /dev/null 2>&1; then
  echo "🔐 Please sign into 1Password CLI:"
  eval "$(op signin < /dev/tty)"
fi

if [ ! -f "${HOME}/.config/chezmoi/key.txt" ]; then
  echo "🔑 Retrieving age private key from 1Password..."
  mkdir -p "${HOME}/.config/chezmoi"
  
  if ! op read "op://Personal/chezmoi-key/notesPlain" > "${HOME}/.config/chezmoi/key.txt" 2>/dev/null; then
    if ! op read "op://Developer/chezmoi-key/notesPlain" > "${HOME}/.config/chezmoi/key.txt" 2>/dev/null; then
      echo "❌ Error: Could not retrieve 'chezmoi-key' from 1Password."
      echo "   Please make sure you have a Secure Note in 1Password named 'chezmoi-key'"
      echo "   with your age private key pasted in the notes field."
      rm -f "${HOME}/.config/chezmoi/key.txt"
      exit 1
    fi
  fi
  
  chmod 600 "${HOME}/.config/chezmoi/key.txt"
  echo "✅ Age private key successfully restored from 1Password."
fi