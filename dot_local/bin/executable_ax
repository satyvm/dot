#!/usr/bin/env bash
set -euo pipefail
# ax - Unified Agent Executor CLI for CLI Proxy API & Nono Sandboxing

show_help() {
  cat << 'EOF2'
ax — Unified Agent Executor

USAGE:
  ax [agent] [sandbox] [extra_args...]
  ax --help | -h
  ax models
  ax quota | q

POSITIONAL PARAMETERS:
  agent       Agent binary to run:
                claude   | c   (default)
                pi       | p
                opencode | o
                crush    | charm | cr
  sandbox     Sandboxing mode:
                safe   | s  (default: Nono sandboxed run, uses .nono.json if present else default profile)
                direct | d  (Direct run without sandboxing)

SUBCOMMANDS:
  --help, -h  Show this help message
  models      Display live available proxy models
  quota, q    Open CLI Proxy API quota dashboard in browser
EOF2
}

show_models() {
  echo "Live Available Models (http://127.0.0.1:8317/v1/models):"
  echo ""
  local response
  response=$(curl -s --max-time 2 -H "Authorization: Bearer sk-dummy" http://127.0.0.1:8317/v1/models 2>/dev/null || true)
  if [[ -n "$response" ]] && command -v jq >/dev/null 2>&1 && echo "$response" | jq -e '.data' >/dev/null 2>&1; then
    echo "$response" | jq -r '.data[] | "  - " + .id + " [Provider: " + (.owned_by // "unknown") + "]"'
  elif [[ -n "$response" ]]; then
    echo "  $response"
  else
    echo "  (CLI Proxy API server not responding on 127.0.0.1:8317)"
  fi
}

show_quota() {
  echo "CLI Proxy API Quota Dashboard:"
  echo "  URL: http://127.0.0.1:8317/management.html#/quota"
  if [[ -z "${DRY_RUN:-}" ]]; then
    open "http://127.0.0.1:8317/management.html#/quota" 2>/dev/null || true
  fi
}

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  show_help
  exit 0
fi

if [[ "${1:-}" == "models" ]]; then
  show_models
  exit 0
fi

if [[ "${1:-}" == "quota" || "${1:-}" == "q" ]]; then
  show_quota
  exit 0
fi

AGENT="claude"
SANDBOX="safe"

parse_agent() {
  case "${1:-}" in
    c|claude)   AGENT="claude" ;;
    p|pi)       AGENT="pi" ;;
    o|opencode) AGENT="opencode" ;;
    r|crush|charm|cr) AGENT="crush" ;;
    *) return 1 ;;
  esac
}

parse_sandbox() {
  case "${1:-}" in
    s|safe)   SANDBOX="safe" ;;
    d|direct) SANDBOX="direct" ;;
    *) return 1 ;;
  esac
}

if parse_agent "${1:-}"; then
  shift
  parse_sandbox "${1:-}" && shift || true
elif parse_sandbox "${1:-}"; then
  shift
fi

# Universal Provider settings mapped to CLI Proxy API
export ANTHROPIC_BASE_URL="http://127.0.0.1:8317"
export ANTHROPIC_API_KEY="sk-dummy"
unset ANTHROPIC_AUTH_TOKEN
export OPENAI_BASE_URL="http://127.0.0.1:8317/v1"
export OPENAI_API_KEY="sk-dummy"

export CLAUDE_CONFIG_DIR="${HOME}/.claude"
export PI_CODING_AGENT_DIR="${HOME}/.config/pi/agent"

# Simplified model defaults (just Gemini proxy models)
export ANTHROPIC_DEFAULT_OPUS_MODEL="claude-opus-4-6-thinking"
export ANTHROPIC_DEFAULT_SONNET_MODEL="gemini-3.6-flash-high"
export ANTHROPIC_DEFAULT_HAIKU_MODEL="gemini-3.5-flash-low"
export ANTHROPIC_DEFAULT_FABLE_MODEL="gemini-3.1-pro-low"
export ANTHROPIC_MODEL="gemini-3.6-flash-high"
export ANTHROPIC_SMALL_FAST_MODEL="gemini-3.5-flash-low"
export OPENAI_MODEL="gemini-3.6-flash-high"

export HERDR_AGENT="$AGENT"
AGENT_CMD="$AGENT"

if [[ "$SANDBOX" == "safe" ]]; then
  if [[ -f "$PWD/.nono.json" ]]; then
    PROFILE=".nono.json"
  elif [[ "$AGENT" == "pi" ]]; then
    PROFILE="default-pi"
  elif [[ "$AGENT" == "opencode" ]]; then
    PROFILE="default-opencode"
  elif [[ "$AGENT" == "crush" ]]; then
    PROFILE="default-crush"
  else
    PROFILE="default-claude"
  fi
  RUN_CMD=(nono run --profile "$PROFILE" --allow-cwd -- "$AGENT_CMD" "$@")
else
  RUN_CMD=("$AGENT_CMD" "$@")
fi

if [[ -n "${DRY_RUN:-}" ]]; then
  echo "AGENT=$AGENT SANDBOX=$SANDBOX"
  echo "HERDR_AGENT=$HERDR_AGENT"
  echo "ANTHROPIC_BASE_URL=$ANTHROPIC_BASE_URL"
  echo "ANTHROPIC_API_KEY=$ANTHROPIC_API_KEY"
  echo "ANTHROPIC_MODEL=$ANTHROPIC_MODEL"
  echo "OPENAI_MODEL=$OPENAI_MODEL"
  echo "EXEC: ${RUN_CMD[*]}"
  exit 0
fi

exec "${RUN_CMD[@]}"
