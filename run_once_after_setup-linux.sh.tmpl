#!/usr/bin/env bash
set -euo pipefail

is_container() {
  [[ -f /.dockerenv || -f /run/.containerenv ]] && return 0
  command -v systemd-detect-virt >/dev/null 2>&1 && systemd-detect-virt --container >/dev/null 2>&1
}

if is_container; then
  echo "Container detected; skipping firewall and fail2ban configuration."
  exit 0
fi

if command -v ufw >/dev/null 2>&1; then
  sudo ufw default deny incoming
  sudo ufw default allow outgoing
  sudo ufw allow ssh
  sudo ufw allow 80/tcp
  sudo ufw allow 443/tcp
  sudo ufw --force enable
else
  echo "UFW is not installed; skipping firewall setup."
fi

if command -v systemctl >/dev/null 2>&1 && command -v fail2ban-client >/dev/null 2>&1; then
  sudo systemctl enable --now fail2ban
else
  echo "fail2ban or systemd is unavailable; skipping fail2ban setup."
fi
