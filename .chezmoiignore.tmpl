# ── Repo-only files (never deployed to home) ─────────────────────────────────
README.md
LICENSE
AGENTS.md
.setup.sh
scripts
cursor-default.code-profile

# ── Ignore encrypted backup files if the decryption key is missing ──────────
{{- if not (stat (joinPath .chezmoi.homeDir ".config/chezmoi/key.txt")) }}
.backup/cursor-default.code-profile
{{- end }}


# ── macOS-only scripts: ignore on Linux ──────────────────────────────────────
{{- if ne .chezmoi.os "darwin" }}
run_once_after_setup-macos.sh.tmpl
{{- end }}

# ── Linux-only scripts: ignore on macOS ──────────────────────────────────────
{{- if ne .chezmoi.os "linux" }}
run_once_after_setup-linux.sh.tmpl
run_onchange_apt-packages.sh.tmpl
{{- end }}

# ── AI agent platform: first milestone is macOS dev only ─────────────────────
{{- if not (and (eq .chezmoi.os "darwin") (eq .profile "dev")) }}
.config/ax
.config/cli-proxy-api
.config/crush
.config/opencode
.config/pi
.config/nono/profiles/default-agent.json
.config/nono/profiles/default-claude.json
.config/nono/profiles/default-crush.json
.config/nono/profiles/default-opencode.json
.config/nono/profiles/default-pi.json
.local/bin/ax
.local/bin/claude
.local/bin/crush
.local/bin/opencode
.local/bin/pi
run_onchange_after_setup-ai-agent-platform.sh.tmpl
{{- end }}

# ── Server profile: skip desktop/GUI scripts ─────────────────────────────────
{{- if eq .profile "server" }}
run_once_after_setup-zend.sh.tmpl
.config/alacritty
.config/ghostty
{{- end }}
