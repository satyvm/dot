# Device-local AI authentication and credentials must never enter the source state.
dot_config/cli-proxy-api/*.json
dot_config/cli-proxy-api/*key*
dot_config/**/auth.json
dot_config/**/credentials.json
dot_pi/**/auth.json
dot_pi/**/credentials.json

# Machine-local source-state, editor, and operating-system clutter.
.DS_Store
.idea/
.vscode/
*.swp
*.swo
*.tmp
*.bak
.chezmoi.local.*

# SSH material and Keychain exports are outside the portable dotfiles boundary.
dot_ssh/
private_dot_ssh/
*Keychain*.keychain-db
