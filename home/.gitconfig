[user]
    name = Satyam
    email = 75127014+satyvm@users.noreply.github.com
    signingkey = ~/.ssh/id_ed25519_1password.pub

[includeIf "gitdir:/Users/smac/Developer/work/"]
    path = ~/.config/git/.work

[core]
    excludesfile = ~/.config/git/ignore
    pager = delta
    autocrlf = input
    editor = nvim

[diff]
    tool = cursor
    colorMoved = default

[delta]
    navigate = true
    light = false
    side-by-side = true
    line-numbers = true

[merge]
    conflictstyle = diff3

[gpg]
    format = ssh

[gpg "ssh"]
    # Use 1Password to sign commits — no local key file needed
    program = "/Applications/1Password.app/Contents/MacOS/op-ssh-sign"

[commit]
    gpgsign = true

[pull]
    rebase = true

[push]
    default = current
    autoSetupRemote = true

[fetch]
    prune = true

[rebase]
    autoStash = true

[alias]
    s   = status -sb
    lg  = log --oneline --graph --decorate --all
    undo = reset --soft HEAD~1
    amend = commit --amend --no-edit
    aliases = config --get-regexp alias
