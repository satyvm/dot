#!/usr/bin/env bash
set -euo pipefail

export PATH="/home/linuxbrew/.linuxbrew/bin:/opt/homebrew/bin:/usr/local/bin:$PATH"

if ! command -v brew >/dev/null 2>&1; then
  echo "Homebrew is required for selected dotfiles packages; install it first, then rerun chezmoi apply."
  exit 0
fi

brew bundle --file=/dev/stdin <<'EOF'
brew "chezmoi"
{{- if .setupCli }}
brew "git"
brew "curl"
brew "wget"
brew "git-delta"
brew "gh"
brew "jj"
brew "lazygit"
brew "starship"
brew "zsh-autosuggestions"
brew "zsh-syntax-highlighting"
brew "zsh-history-substring-search"
brew "thefuck"
brew "bat"
brew "eza"
brew "fd"
brew "fzf"
brew "ripgrep"
brew "jq"
brew "glow"
brew "tlrc"
brew "zoxide"
brew "neovim"
brew "tmux"
brew "tree-sitter-cli"
brew "pet"
brew "btop"
brew "watch"
{{- end }}
{{- if .setupDeveloper }}
brew "fnm"
brew "go"
brew "gopls"
brew "rust-analyzer"
brew "postgresql@18"
brew "mise"
brew "clang-format"
brew "freetype"
brew "gettext"
brew "gperf"
brew "imlib2"
brew "lcov"
brew "librsvg"
brew "libxfixes"
brew "libxft"
brew "libxi"
brew "libxinerama"
brew "libxml2"
brew "lua"
brew "pkg-config"
brew "tpm"
brew "kondo"
brew "shellcheck"
brew "commitizen"
brew "docker"
{{- if eq .chezmoi.os "darwin" }}
brew "colima"
brew "docker-compose"
{{- end }}
{{- end }}
{{- if .setupAi }}
brew "herdr"
brew "nono"
brew "uv"
brew "opencode"
brew "pi-coding-agent"
brew "charmbracelet/tap/crush"
{{- if eq .aiMode "local" }}
brew "cliproxyapi"
{{- end }}
{{- if eq .chezmoi.os "darwin" }}
cask "claude-code"
{{- else }}
brew "claude-code"
{{- end }}
{{- end }}
{{- if and (eq .chezmoi.os "darwin") (or (eq .guiTier "minimum") (eq .guiTier "all")) }}
cask "raycast"
cask "jordanbaird-ice"
cask "shottr"
cask "hyperkey"
cask "ghostty"
cask "font-jetbrains-mono-nerd-font"
{{- end }}
{{- if and (eq .chezmoi.os "darwin") (eq .guiTier "all") }}
brew "mas"
cask "helium-browser"
cask "discord"
cask "telegram"
cask "whatsapp"
cask "notion-calendar"
cask "notion"
cask "zotero"
cask "dockdoor"
cask "TheBoredTeam/boring-notch/boring-notch"
cask "iina"
cask "appcleaner"
cask "veracrypt-fuse-t"
cask "google-drive"
cask "protonvpn"
cask "handy"
cask "zen"
cask "google-gemini"
cask "zed"
cask "antigravity-ide"
cask "alacritty"
cask "yaak"
cask "utm"
cask "onyx"
cask "basictex"
{{- end }}
EOF
