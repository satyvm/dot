#!/usr/bin/env bash
set -euo pipefail

export PATH="$HOME/.local/bin:$HOME/.cargo/bin:/home/linuxbrew/.linuxbrew/bin:/opt/homebrew/bin:/usr/local/bin:$PATH"

if ! command -v rustup >/dev/null 2>&1; then
  curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
fi
[[ -f "$HOME/.cargo/env" ]] && source "$HOME/.cargo/env"

if ! command -v uv >/dev/null 2>&1; then
  curl -LsSf https://astral.sh/uv/install.sh | sh
fi
if command -v uv >/dev/null 2>&1; then
  uv python install
  for tool in pylint black isort; do uv tool install "$tool" 2>/dev/null || true; done
fi

if command -v fnm >/dev/null 2>&1; then
  eval "$(fnm env)"
  if ! command -v node >/dev/null 2>&1; then
    fnm install --lts
    fnm default lts-latest
    corepack enable
  fi
fi
if ! command -v bun >/dev/null 2>&1; then curl -fsSL https://bun.sh/install | bash; fi
if command -v mise >/dev/null 2>&1; then
  for tool in gcloud aws-cli kubectl kubectx kubens k9s; do mise use -g "${tool}@latest" || true; done
fi
