# Required Coolify runtime values. Replace every example before deployment.
SERVER_DEV_PATH=/home/ubuntu/dev
REMOTE_UID=1000
REMOTE_GID=1000
DEV_SSH_PORT=2222
DEV_SSH_PUBLIC_KEY=ssh-ed25519 AAAA_REPLACE_WITH_DEDICATED_CONTAINER_KEY hermes-dev
CLIPROXY_CLIENT_KEY=replace-with-a-long-random-client-key
CLIPROXY_MANAGEMENT_KEY=replace-with-a-different-long-random-management-key
HERMES_WEBUI_PASSWORD=replace-with-a-long-random-password

# Optional identity and source overrides.
REMOTE_DOTFILES_REPO=https://github.com/satyvm/dot.git
REMOTE_GIT_NAME=Satyam
REMOTE_GIT_EMAIL=75127014+satyvm@users.noreply.github.com
GITHUB_PERSONAL_ACCESS_TOKEN=

# Version pins used by the image build.
HERMES_WEBUI_VERSION=0.51.92
HERMES_AGENT_VERSION=0.18.2
